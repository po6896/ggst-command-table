            ["エラルルーモ", "初段ダッシュキャンセル可"],
            ["アグレーサオルドーノ", "空中 2 段技 ／ 1 段目 S 剣 / 2 段目 HS 剣"]
          ]
        }
      },
      {
        "title": "覚醒の細部",
