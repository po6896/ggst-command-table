  "mechanicDetail": {
    "intro": "ディール (236) でカードを設置 → ミストファイナー (214) で斬る → カード位置で Turn Up 追加判定が発生。設置 → 起爆の 2 段構え。",
    "sections": [
      {
        "title": "ミストファイナー — 214+P/K/S",
        "summary": "抜刀技。ボタン保持で構え継続、44/66 で姿消しステップ可。",
        "table": {
          "headers": ["版", "方向", "性能"],
          "rows": [
            ["P 版", "斜め上", "上中段 ／ 大きく吹き飛ばし"],
            ["K 版", "横", "中段 ／ スライドダウン ／ リーチ長"],
            ["S 版", "斜め下", "下段 ／ 受け身不能浮き"],
            ["空中版", "各方向", "中段 ／ 追撃容易"]
          ]
        }
      },
      {
        "title": "ディール — 236+P/K/S 設置",
        "summary": "前方にカードを投げて壁に突き刺す。攻撃判定なし。",
        "table": {
          "headers": ["版", "飛距離", "持続"],
          "rows": [
            ["P 版", "短距離", "5 秒 ／ 被弾で消滅"],
            ["K 版", "中距離", "5 秒経過で消失"],
            ["S 版", "長距離", "ダウンで消滅"]
          ]
        },
        "footnote": "同時設置は 1 枚のみ。空中ディール (空中 236HS) はカード + 手元判定の 2 ヒット。"
      },
      {
        "title": "ターンアップ — カード追加判定",
        "summary": "ミストファイナーの斬り方向でカード位置の追撃が変化。",
        "table": {
          "headers": ["斬撃", "追撃方向", "効果"],
          "rows": [
